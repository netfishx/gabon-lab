# Stage 1: Build the application
FROM eclipse-temurin:17-jdk-jammy AS builder

# Install Maven
RUN apt-get update && \
    apt-get install -y maven && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /workspace/app

# Copy only pom.xml files first to leverage Docker layer caching for dependencies
COPY pom.xml .
COPY gabon-admin/pom.xml gabon-admin/
COPY gabon-common/pom.xml gabon-common/
COPY gabon-service/pom.xml gabon-service/

# Download dependencies in a separate layer (cached unless pom.xml changes)
RUN --mount=type=cache,target=/root/.m2 mvn dependency:go-offline -Ptest || true

# Now copy the source code
COPY gabon-admin/src gabon-admin/src
COPY gabon-common/src gabon-common/src
COPY gabon-service/src gabon-service/src

# Build the application using Maven cache, activating the 'test' profile
# This will build all modules defined in the root pom.xml.
# The gabon-admin.jar will be in ./gabon-admin/target/
RUN --mount=type=cache,target=/root/.m2 mvn clean package -DskipTests -Ptest

# Stage 2: Create the final lightweight image
FROM eclipse-temurin:17-jre-jammy

WORKDIR /app

# Copy only the built JAR for gabon-admin from the builder stage
# Adjust the path if your JAR is located elsewhere in the builder stage
COPY --from=builder /workspace/app/gabon-admin/target/gabon-admin.jar app.jar

# Expose the port the application will run on (as specified in your ENTRYPOINT)
EXPOSE 51011

# Run the application with specified memory, Spring profile, and port
ENTRYPOINT ["java", "-Xms512m", "-Xmx512m", "-jar", "app.jar", "--spring.profiles.active=dev", "--server.port=51011"]
