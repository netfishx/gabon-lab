<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gabon.admin.mapper.DailyVideoReportMapper">

    <resultMap id="BaseResultMap" type="com.gabon.admin.model.entity.DailyVideoReport">
        <id column="id" property="id"/>
        <result column="report_date" property="reportDate"/>
        <result column="customer_id" property="customerId"/>
        <result column="customer_name" property="customerName"/>
        <result column="is_vip" property="isVip"/>
        <result column="click_count" property="clickCount"/>
        <result column="valid_count" property="validCount"/>
        <result column="settlement_amount" property="settlementAmount"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="create_by" property="createBy"/>
        <result column="update_by" property="updateBy"/>
        <result column="deleted_flag" property="deletedFlag"/>
    </resultMap>

    <!-- 分页查询每日视频报表 -->
    <select id="selectDailyReports" resultMap="BaseResultMap">
        SELECT *
        FROM daily_video_reports
        WHERE report_date BETWEEN #{startDate} AND #{endDate}
          AND deleted_flag IS NULL
        <if test="customerId != null">
            AND customer_id = #{customerId}
        </if>
        <if test="customerName != null and customerName != ''">
            AND customer_name LIKE CONCAT('%', #{customerName}, '%')
        </if>
        ORDER BY report_date DESC, customer_id ASC
    </select>

    <!-- 查询日期范围内的视频报表汇总 -->
    <select id="getSummaryStatistics" resultType="java.util.HashMap">
        SELECT
            report_date AS date,
            COALESCE(SUM(click_count), 0) AS totalClickCount,
            COALESCE(SUM(valid_count), 0) AS totalValidCount,
            COALESCE(SUM(settlement_amount), 0) AS totalSettlementAmount
        FROM daily_video_reports
        WHERE report_date BETWEEN #{startDate} AND #{endDate}
          AND deleted_flag IS NULL
        GROUP BY report_date
        ORDER BY report_date DESC
    </select>

</mapper>
